<?xml version="1.0" encoding="UTF-8"?>
<launch>
  <arg name="ego_topic" default="/morai/ego_topic" />
  <arg name="velocity_scale_to_kph" default="1.0" />
  <arg name="audio_backend" default="paplay" />
  <arg name="volume" default="0.55" />
  <arg name="sample_rate" default="48000" />
  <arg name="engine_style" default="ev_spaceship" />
  <arg name="engine_cylinders" default="4" />
  <arg name="ev_low_drone_gain" default="2.0" />
  <arg name="ev_high_layer_gain" default="0.70" />
  <arg name="chunk_ms" default="10.0" />
  <arg name="audio_latency_ms" default="50.0" />
  <arg name="audio_process_time_ms" default="10.0" />
  <arg name="state_publish_hz" default="20.0" />

  <node pkg="control" type="morai_engine_sound.py" name="morai_engine_sound" output="screen">
    <param name="ego_topic" value="$(arg ego_topic)" />
    <param name="velocity_scale_to_kph" value="$(arg velocity_scale_to_kph)" />
    <param name="audio_backend" value="$(arg audio_backend)" />
    <param name="volume" value="$(arg volume)" />
    <param name="sample_rate" value="$(arg sample_rate)" />
    <param name="engine_style" value="$(arg engine_style)" />
    <param name="engine_cylinders" value="$(arg engine_cylinders)" />
    <param name="ev_low_drone_gain" value="$(arg ev_low_drone_gain)" />
    <param name="ev_high_layer_gain" value="$(arg ev_high_layer_gain)" />
    <param name="chunk_ms" value="$(arg chunk_ms)" />
    <param name="audio_latency_ms" value="$(arg audio_latency_ms)" />
    <param name="audio_process_time_ms" value="$(arg audio_process_time_ms)" />
    <param name="state_publish_hz" value="$(arg state_publish_hz)" />

    <param name="max_speed_kph" value="120.0" />
    <param name="idle_rpm" value="800.0" />
    <param name="redline_rpm" value="7000.0" />
    <param name="soft_limit_rpm" value="6800.0" />
    <param name="max_rpm" value="7200.0" />
    <param name="upshift_rpm" value="6500.0" />
    <param name="downshift_rpm" value="2500.0" />
    <param name="rpm_rise_tau_s" value="0.030" />
    <param name="rpm_fall_tau_s" value="0.050" />
    <param name="speed_rpm_curve_exponent" value="0.72" />
    <param name="upshift_duration_s" value="0.12" />
    <param name="downshift_duration_s" value="0.15" />
    <param name="shift_cooldown_s" value="0.18" />
    <param name="blip_gain" value="1.0" />
    <param name="kickdown_throttle" value="0.85" />
    <param name="brake_downshift" value="0.30" />
    <rosparam param="gear_max_speeds_kph">[130.0]</rosparam>
  </node>
</launch>
