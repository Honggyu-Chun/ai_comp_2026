<?xml version="1.0" encoding="UTF-8"?>
<launch>
  <arg name="udp_module_root" default="" />

  <!-- MORAI ObjectInfo (sim host port 7605 -> destination port 7505) -->
  <arg name="obj_ip" default="127.0.0.1" />
  <arg name="obj_port" default="7505" /> <!-- Destination Port (bind 수신) -->

  <arg name="hz" default="20.0" />
  <arg name="frame_id" default="map" />
  <arg name="topic" default="/Object_topic" />

  <node pkg="morai_gadis_set" type="object_info_udp_bridge.py" name="object_info_udp_bridge" output="screen">
    <param name="udp_module_root" value="$(arg udp_module_root)" />
    <param name="obj_ip" value="$(arg obj_ip)" />
    <param name="obj_port" value="$(arg obj_port)" />
    <param name="hz" value="$(arg hz)" />
    <param name="frame_id" value="$(arg frame_id)" />
    <param name="topic" value="$(arg topic)" />
  </node>
</launch>
