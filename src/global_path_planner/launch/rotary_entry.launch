<?xml version="1.0" encoding="utf-8"?>
<!-- 로터리(회전교차로) 진입 판단.
     /odometry/filtered + /obstacle_info → 갭수용 판단 → /rotary/stop_wall_s, /rotary/speed_cap_kph.
     speed_profiler 가 이 두 값을 정지벽/속도상한으로 반영. 진출은 전역경로가 처리. -->
<launch>
  <!-- ===== 토픽 ===== -->
  <arg name="ego_topic"      default="/odometry/filtered" /> <!-- 자차 pose/속도 (nav_msgs/Odometry, EKF융합 UTM) -->
  <arg name="obstacle_topic" default="/obstacle_info" />    <!-- 장애물 (base_link 상대) -->
  <arg name="timer_rate_hz"  default="30.0" />
  <arg name="ego_timeout"    default="0.5" />               <!-- 자차 stale[s] 넘으면 발행 보류 -->
  <arg name="publish_markers" default="true" />

  <!-- ===== 로터리 기하 (UTM 좌표, /gps_utm_odom 기준). fit_rotary_circle.py 로 측정 권장 ===== -->
  <arg name="center_x"        default="-101.5695" />       <!-- 로터리 중심 x [m] (UTM, fit) -->
  <arg name="center_y"        default="343.7351" />       <!-- 로터리 중심 y [m] (UTM, fit) -->
  <arg name="ring_radius_m"   default="18.0241" />      <!-- 순환 차로 중심선 반경 [m] (fit, 잔차 0.078m) -->
  <arg name="ring_band_m"     default="3.0" />       <!-- |r-R|<band 이면 순환차로 판정 -->
  <arg name="theta_entry_rad" default="-1.1460" />   <!-- 진입각: 경로가 링에 합류하는 UTM 좌표(-94,327) -->
  <arg name="theta_exit_rad"  default="-0.4611" />       <!-- 진출각: (-86,336) -->
  <arg name="dir"             default="1" />         <!-- 순환방향 +1=반시계(CCW). 코어가 데이터로 재검증 -->

  <!-- ===== 자차 발진 모델 ===== -->
  <arg name="s_stopline_to_conflict_m" default="6.0" /> <!-- 정지선→충돌점 경로거리 [m] -->
  <arg name="a_launch_mps2"   default="1.5" />       <!-- 발진 가속도 [m/s^2] -->
  <arg name="v_ring_kph"      default="20.0" />      <!-- 로터리 내부 상한 속도 [kph] (곡선 링 추종 한계 → 보수적) -->
  <arg name="ego_length_m"    default="4.6" />       <!-- 자차 길이 [m] -->

  <!-- ===== 갭 수용 판정 ===== -->
  <arg name="tau_lead_s"      default="1.0" />       <!-- 도착 전 여유 [s] -->
  <arg name="tau_lag_s"       default="1.5" />       <!-- 통과 후 여유 [s] -->
  <arg name="v_agent_min_mps" default="0.5" />       <!-- 이보다 느리면 순환차 아님 -->
  <arg name="go_confirm_frames" default="5" />       <!-- GO 연속확정 프레임 (채터링 방지) -->
  <arg name="deadlock_timeout_s" default="20.0" />   <!-- HOLD 지속 시 마진 완화 시작 [s] -->
  <arg name="relaxed_scale"   default="0.7" />       <!-- 데드락 시 tau 완화 계수 -->

  <!-- ===== FSM 활성 ===== -->
  <arg name="activate_dist_m" default="40.0" />      <!-- 진입점 유클리드 거리 이하일 때 활성 [m] -->
  <arg name="commit_dist_m"   default="20.0" />      <!-- 이 거리 이내+갭열림에서만 COMMIT 잠금(멀리서 조기진입 방지) [m] -->
  <arg name="approach_cap_kph" default="30.0" />     <!-- 접근 속도 상한 [kph] -->
  <arg name="allow_rearm"     default="true" />     <!-- DONE 후 재무장(다랩/테스트) -->

  <node name="rotary_entry" pkg="global_path_planner" type="rotary_entry_node" output="screen" respawn="true">
    <param name="ego_topic"      value="$(arg ego_topic)" type="str" />
    <param name="obstacle_topic" value="$(arg obstacle_topic)" type="str" />
    <param name="timer_rate_hz"  value="$(arg timer_rate_hz)" type="double" />
    <param name="ego_timeout"    value="$(arg ego_timeout)" type="double" />
    <param name="publish_markers" value="$(arg publish_markers)" type="bool" />

    <param name="center_x"        value="$(arg center_x)" type="double" />
    <param name="center_y"        value="$(arg center_y)" type="double" />
    <param name="ring_radius_m"   value="$(arg ring_radius_m)" type="double" />
    <param name="ring_band_m"     value="$(arg ring_band_m)" type="double" />
    <param name="theta_entry_rad" value="$(arg theta_entry_rad)" type="double" />
    <param name="theta_exit_rad"  value="$(arg theta_exit_rad)" type="double" />
    <param name="dir"             value="$(arg dir)" type="int" />

    <param name="s_stopline_to_conflict_m" value="$(arg s_stopline_to_conflict_m)" type="double" />
    <param name="a_launch_mps2"   value="$(arg a_launch_mps2)" type="double" />
    <param name="v_ring_kph"      value="$(arg v_ring_kph)" type="double" />
    <param name="ego_length_m"    value="$(arg ego_length_m)" type="double" />

    <param name="tau_lead_s"      value="$(arg tau_lead_s)" type="double" />
    <param name="tau_lag_s"       value="$(arg tau_lag_s)" type="double" />
    <param name="v_agent_min_mps" value="$(arg v_agent_min_mps)" type="double" />
    <param name="go_confirm_frames" value="$(arg go_confirm_frames)" type="int" />
    <param name="deadlock_timeout_s" value="$(arg deadlock_timeout_s)" type="double" />
    <param name="relaxed_scale"   value="$(arg relaxed_scale)" type="double" />

    <param name="activate_dist_m" value="$(arg activate_dist_m)" type="double" />
    <param name="commit_dist_m"   value="$(arg commit_dist_m)" type="double" />
    <param name="approach_cap_kph" value="$(arg approach_cap_kph)" type="double" />
    <param name="allow_rearm"     value="$(arg allow_rearm)" type="bool" />
  </node>
</launch>
